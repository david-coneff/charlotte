<!DOCTYPE html>
<html>
<head>
<meta http-equiv="x-ua-compatible" content="ie=edge">
<meta charset="utf-8">
<title>Domain Crawler</title>
<hta:application
  id="crawlApp"
  applicationname="DomainCrawler"
  border="thin"
  borderstyle="normal"
  caption="yes"
  maximizebutton="yes"
  minimizebutton="yes"
  scroll="auto"
  singleinstance="yes"
  sysmenu="yes"
  contextmenu="no" />
<!--
  crawl-gui.hta — friendly Windows front-end for crawl.js

  Double-click to open. Fill in the options, click "Start crawl". It builds and
  runs:  node crawl.js <start-url> [options]  in the background, streams the
  output here, and lets you open the report when it finishes.

  Requirements:
    * Windows (uses built-in mshta.exe — no install)
    * Node.js available on PATH (https://nodejs.org)
    * crawl.js in the same folder as this file (auto-detected)

  JScript note: this engine is ES3/ES5 only — no arrow functions, let/const,
  or template literals. Keep edits in that dialect.
-->
<style>
  body { font: 15px "Segoe UI", Tahoma, sans-serif; background: #0f1115; color: #e6e9ef; margin: 0; }
  .wrap { padding: 18px 22px; }
  h1 { font-size: 22px; margin: 0 0 3px; }
  .sub { color: #9aa4b2; font-size: 14px; margin: 0 0 16px; }
  .tabbar { margin: 0 0 16px; border-bottom: 1px solid #2c3340; }
  .tabbtn { background: transparent; color: #9aa4b2; border: 1px solid transparent; border-bottom: none; border-radius: 8px 8px 0 0; padding: 9px 18px; font-weight: 600; cursor: pointer; margin: 0 4px -1px 0; }
  .tabbtn.active { background: #1a1e26; color: #e6e9ef; border-color: #2c3340; }
  .tabpanel { display: none; }
  .tabpanel.active { display: block; }
  fieldset { border: 1px solid #2c3340; border-radius: 8px; margin: 0 0 16px; padding: 14px 16px; }
  legend { color: #9aa4b2; font-size: 13px; text-transform: uppercase; letter-spacing: .05em; padding: 0 6px; }
  .row { margin: 9px 0; }
  label.f { display: inline-block; width: 168px; color: #9aa4b2; vertical-align: middle; font-size: 15px; }
  input, select { font: 15px "Segoe UI", Tahoma, sans-serif; }
  input.t, input.n, select { background: #222834; color: #e6e9ef; border: 1px solid #2c3340; border-radius: 6px; padding: 7px 9px; }
  input.t { width: 380px; }
  input.n { width: 100px; }
  input.wide { width: 380px; }
  .hint { color: #6b7585; font-size: 13px; margin-left: 8px; }
  .cols { width: 100%; }
  .cols td { vertical-align: top; padding-right: 22px; }
  button { font: 15px "Segoe UI", sans-serif; font-weight: 600; border: 0; border-radius: 7px; padding: 10px 18px; cursor: pointer; margin-right: 8px; }
  button.go { background: #5db0ff; color: #06121f; }
  button.sec { background: #222834; color: #e6e9ef; border: 1px solid #2c3340; }
  button[disabled] { opacity: .5; cursor: default; }
  .cmd { font: 13px Consolas, monospace; background: #0b0d11; border: 1px solid #2c3340; border-radius: 6px; padding: 9px 11px; color: #9aa4b2; word-break: break-all; min-height: 18px; max-width: 820px; }
  .opts { display: inline-block; vertical-align: top; }
  .opt { display: block; color: #9aa4b2; margin: 0 0 7px; cursor: pointer; }
  .opt:last-child { margin-bottom: 0; }
  .opt input { margin: 0 7px 0 0; vertical-align: middle; }
  #liveout { width: 100%; height: 240px; background: #0b0d11; color: #c8d0db; border: 1px solid #2c3340; border-radius: 6px; font: 13px Consolas, monospace; resize: vertical; }
  .statchip { display: inline-block; background: #1a1e26; border: 1px solid #2c3340; border-radius: 7px; padding: 7px 13px; margin: 0 8px 7px 0; font-size: 15px; }
  .statchip b { color: #5db0ff; }
  .statchip.ok b { color: #4ade80; }
  .statchip.warn { border-color: #fbbf24; }
  .statchip.warn b, .statchip.warn { color: #fbbf24; }
  .recent { width: 100%; height: 110px; overflow: auto; background: #0b0d11; color: #9aa4b2; border: 1px solid #2c3340; border-radius: 6px; font: 13px Consolas, monospace; margin: 0; padding: 9px 11px; white-space: pre; }
  .status { margin: 10px 0; font-size: 14px; }
  .ok { color: #4ade80; } .bad { color: #f87171; } .muted { color: #9aa4b2; }
  code { background: #222834; padding: 1px 5px; border-radius: 4px; }
  .urlrow { margin-bottom: 6px; }
  .urlinput { width: 360px; background: #222834; color: #e6e9ef; border: 1px solid #2c3340; border-radius: 6px; padding: 7px 9px; font: 15px "Segoe UI", Tahoma, sans-serif; }
  .urlrm { padding: 6px 11px; margin-left: 6px; }
  html, body { overflow-x: hidden; }
  a { color: #5db0ff; }
</style>
</head>
<body>
<div class="wrap" id="wrap">
  <h1>Domain Crawler</h1>
  <p class="sub">A friendly front-end for crawl.js. Requires Node.js on your PATH.</p>

  <div class="tabbar">
    <button type="button" class="tabbtn active" id="tabbtn-settings" onclick="showTab('settings')">⚙ Settings</button>
    <button type="button" class="tabbtn" id="tabbtn-run" onclick="showTab('run')">▶ Run &amp; monitor</button>
  </div>

  <div class="tabpanel active" id="tab-settings">
  <fieldset>
    <legend>Target</legend>
    <div class="row" style="align-items:flex-start">
      <label class="f">Start URLs</label>
      <span id="urlRows"></span>
    </div>
    <div class="row">
      <label class="f">&nbsp;</label>
      <button class="sec" type="button" onclick="addUrlRow('')">+ Add another site</button>
      <span class="hint">each site is crawled sequentially with the same settings below · default URLs load from crawl-gui-domains.txt · option defaults from crawl-gui-config.txt</span>
    </div>
    <div class="row">
      <label class="f" for="scope">Crawl scope</label>
      <select id="scope" onchange="toggleInputs();updatePreview()">
        <option value="domain">Entire domain (whole site)</option>
        <option value="path">Only under the start URL's path</option>
        <option value="custom">Custom path prefix&hellip;</option>
      </select>
    </div>
    <div class="row" id="prefixRow" style="display:none">
      <label class="f" for="pathPrefix">Path prefix</label>
      <input class="t" type="text" id="pathPrefix" value="" onkeyup="updatePreview()">
      <span class="hint">e.g. /mysubsection</span>
    </div>
  </fieldset>

  <fieldset>
    <legend>Crawl limits &amp; rate limiting</legend>
    <table class="cols"><tr><td>
      <div class="row"><label class="f" for="maxPages">Max pages</label><input class="n" type="text" id="maxPages" value="200" onkeyup="updatePreview()"> <label class="hint" style="color:#9aa4b2"><input type="checkbox" id="noPages" checked onclick="toggleInputs();updatePreview()"> no limit</label></div>
      <div class="row"><label class="f" for="maxDepth">Max depth</label><input class="n" type="text" id="maxDepth" value="3" onkeyup="updatePreview()"> <label class="hint" style="color:#9aa4b2"><input type="checkbox" id="noDepth" checked onclick="toggleInputs();updatePreview()"> no limit</label></div>
      <div class="row"><label class="f" for="timeout">Timeout (ms)</label><input class="n" type="text" id="timeout" value="20000" onkeyup="updatePreview()"></div>
    </td><td>
      <div class="row"><label class="f" for="concurrency">Concurrency</label><input class="n" type="text" id="concurrency" value="2" onkeyup="updatePreview()"><span class="hint">requests at once</span></div>
      <div class="row"><label class="f" for="delay">Delay (ms)</label><input class="n" type="text" id="delay" value="250" onkeyup="updatePreview()"><span class="hint">pause between requests</span></div>
      <div class="row"><label class="f" for="rps">Max req/sec</label><input class="n" type="text" id="rps" value="2" onkeyup="updatePreview()"><span class="hint">polite default ≈2/sec; 0 = no cap</span></div>
    </td></tr></table>
    <div class="row"><span class="hint" style="margin-left:0">Defaults are deliberately gentle. The crawler also honors <code>robots.txt</code> Crawl-delay and automatically backs off &amp; retries if the server returns 429/503 (rate limiting).</span></div>
    <div class="row">
      <label class="f" style="vertical-align:top">Options</label>
      <div class="opts">
        <label class="opt" title="Render each page in a real browser (Microsoft Edge) to find links a JavaScript-built site (Laserfiche WebLink, SharePoint, most document portals) loads client-side, which the plain static crawl can't see. The found links are then verified and their documents scanned. Needs Playwright installed (npm install playwright). Uncheck for a plain static crawl."><input type="checkbox" id="discoverJs" checked onclick="updatePreview()"> <b>Discover (JS site)</b> — render with a browser first (for WebLink/SharePoint/SPAs)</label>
        <label class="opt" title="Laserfiche WebLink only: a document is a DocView.aspx?id=N viewer PAGE, not a file. With this on, discover treats those as documents — recording the file-download URL (ElectronicFile.aspx?docid=N) for scanning instead of rendering each viewer page. On a repository with thousands of documents this is a huge speedup and is what lets crawl.js scan the links inside the documents. Harmless on non-Laserfiche sites (no DocView.aspx → no effect). Only applies when Discover (JS site) is on."><input type="checkbox" id="laserfiche" checked onclick="updatePreview()"> &nbsp;&nbsp;↳ <b>Laserfiche document mode</b> — scan DocView.aspx documents (don't render each viewer)</label>
        <label class="opt"><input type="checkbox" id="includeSub" checked onclick="updatePreview()"> Treat subdomains as internal</label>
        <label class="opt"><input type="checkbox" id="checkExternal" checked onclick="updatePreview()"> Verify external links resolve</label>
        <label class="opt"><input type="checkbox" id="recheck" checked onclick="updatePreview()"> Re-test failed links once at the end</label>
        <label class="opt"><input type="checkbox" id="scanDocs" checked onclick="updatePreview()"> Scan links inside documents (PDF/Office)</label>
        <label class="opt"><input type="checkbox" id="browser" checked onclick="onBrowserToggle()"> Browser mode (desktop UA, fewer false dead links)</label>
        <label class="opt">Paginate report:
          <select id="pageSize" onchange="updatePreview()" style="margin-left:6px;vertical-align:middle">
            <option value="off">Off — show all rows on one page</option>
            <option value="250">250 rows per page</option>
            <option value="500">500 rows per page</option>
            <option value="1000" selected>1,000 rows per page</option>
            <option value="2500">2,500 rows per page</option>
            <option value="5000">5,000 rows per page</option>
          </select></label>
        <label class="opt"><input type="checkbox" id="allowlistExport" onclick="updatePreview()"> Allowlist export tools in report (legacy; off by default)</label>
      </div>
    </div>
    <div class="row">
      <label class="f" for="userAgent">User-Agent</label>
      <input class="t" type="text" id="userAgent" value="charlotte-crawler/1.0 (+local)" onkeyup="updatePreview()">
    </div>
    <div class="row">
      <label class="f" for="seen">Dedup index</label>
      <select id="seen" onchange="updatePreview()">
        <option value="memory">In-memory (fastest)</option>
        <option value="compact" selected>Compact (low RAM, fixed)</option>
        <option value="disk">Disk (lowest RAM, slowest)</option>
      </select>
      <span class="hint">how visited URLs are remembered</span>
    </div>
  </fieldset>

  <fieldset>
    <legend>Output &amp; allowlist</legend>
    <div class="row"><label class="f" for="workDir">Output folder</label><input class="wide" type="text" id="workDir" value="" onkeyup="updatePreview()"><span class="hint">where files are written</span></div>
    <div class="row"><label class="f" for="out">Report file</label><input class="wide" type="text" id="out" value="crawl-report.html" onkeyup="updatePreview()"></div>
    <div class="row"><label class="f" for="allowlist">Allowlist file</label><input class="wide" type="text" id="allowlist" value="crawl-allowlist.txt" onkeyup="updatePreview()"><span class="hint">suppress known-broken links</span></div>
    <div class="row"><label class="f" for="json">JSON file</label><input class="wide" type="text" id="json" value="" onkeyup="updatePreview()"><span class="hint">optional, leave blank to skip</span></div>
    <div class="row"><label class="f" for="log">Progress log</label><input class="wide" type="text" id="log" value="crawl-progress.log" onkeyup="toggleInputs();updatePreview()"><span class="hint">live trail; partitioned into parts</span></div>
    <div class="row"><label class="f" for="checkpoint">Checkpoint (pages)</label><input class="n" type="text" id="checkpoint" value="25" onkeyup="updatePreview()"><span class="hint">snapshot report every N pages; 0 = off</span></div>
  </fieldset>
  </div><!-- /tab-settings -->

  <div class="tabpanel" id="tab-run">
  <div class="row"><span class="muted" style="font-size:13px">Command preview:</span></div>
  <div class="cmd" id="preview"></div>

  <div class="row" style="margin-top:14px">
    <button class="go" id="startBtn" onclick="startCrawl()">Start crawl</button>
    <button class="sec" id="pauseBtn" onclick="togglePause()" disabled>Pause</button>
    <button class="sec" id="stopBtn" onclick="stopCrawl()" disabled>Stop</button>
    <button class="sec" id="reportBtn" onclick="openReport()">Open crawl report</button>
    <button class="sec" id="recheckBtn" onclick="recheckLinks()" title="Re-probe only the broken links from the last crawl, using the current settings (e.g. request rate). The report's broken-link list is corrected and de-duplicated.">Re-check broken links</button>
    <button class="sec" id="rebuildBtn" onclick="rebuildReport()" title="Regenerate the HTML report from the last crawl's data (crawl-gui-report.json) using this version of Charlotte — no re-crawl. Use it after updating Charlotte to get new report features on an old crawl.">Rebuild report</button>
    <button class="sec" id="resumeBtn" onclick="startCrawl(true)" disabled title="Continue an interrupted crawl from where it stopped — it does not re-crawl pages already done. Available after a crawl is stopped or errors out.">Resume crawl</button>
    <button class="sec" onclick="openFolder()">Open output folder</button>
    <button class="sec" onclick="copyCommand()">Copy command</button>
  </div>

  <div class="status" id="status">&nbsp;</div>

  <div id="statsBar" style="display:none">
    <span class="statchip"><span id="lblCount">Crawled</span>: <b id="statCount">0</b></span>
    <span class="statchip ok" id="goodChip"><span id="lblGood">Good</span>: <b id="statGood">0</b></span>
    <span class="statchip" id="brokenChip"><span id="lblBroken">Broken (internal)</span>: <b id="statBroken">0</b></span>
    <span class="statchip" id="blockedChip"><span id="lblBlocked">Blocked/uncertain</span>: <b id="statBlocked">0</b></span>
    <span class="statchip" id="extChip">External: <b>0</b> found</span>
    <span class="statchip" id="docChip" title="Documents scanned (PDF/Office) and the hyperlink instances found inside them. After the crawl finishes it also shows unique destinations and how many are broken/blocked.">Docs: <b id="statDocs">0</b> · <b id="statDocLinks">0</b> links<span id="statDocBad"></span></span>
    <span class="statchip">Elapsed: <b id="statTime">0:00</b></span>
    <span class="statchip">Rate: <b id="statRate">0</b>/min</span>
    <span class="statchip" id="statActivity">starting&hellip;</span>
  </div>
  <div id="recentBox" style="display:none">
    <div class="muted" style="font-size:13px;margin:8px 0 3px">Last crawled (newest at bottom):</div>
    <pre id="recent" class="recent"></pre>
  </div>

  <div class="muted" style="font-size:13px;margin:8px 0 3px">Live log (the crawler's progress log):</div>
  <textarea id="liveout" readonly wrap="off"></textarea>
  </div><!-- /tab-run -->
</div>

<script language="JScript">
var shell = new ActiveXObject("WScript.Shell");
var fso   = new ActiveXObject("Scripting.FileSystemObject");
var scriptDir = "";   // folder this .hta lives in
var jsPath = "";      // absolute path to crawl.js
var renderPath = "";  // absolute path to crawl-render.js (for the Discover/JS-site option)
var logPath = "";     // temp log file for the current run
var batPath = "";     // temp batch file for the current run
var timer = null;
var running = false;
var runMode = "crawl";  // "crawl" | "recheck" | "rebuild" — tailors the live status / finish messages
var startMs = 0;        // crawl start time (ms)
var lastCount = 0;      // pages counted at last change
var lastChangeMs = 0;   // when the count last increased (for stuck detection)
var livePath = "";      // the crawler's progress log we tail (lock-free, live)
var errPath = "";       // captured node stdout/stderr (for launch failures)
var stopPath = "";      // Stop control file
var pausePath = "";     // Pause control file
var tunePath = "";      // Live re-tune file (delay/rps/timeout applied on Resume)
var isPaused = false;
// Incremental log parsing state (so huge logs don't get re-read/re-parsed each
// poll — that was making the live counts read 0 on large crawls).
var gPos = 0, gBuf = "", gTail = "";
var gCrawled = 0, gGood = 0, gBroken = 0, gBlocked = 0;
var gExtFound = 0, gExtChecked = 0, gExtTotal = 0, gExtBad = 0;
var gDocs = 0, gDocLinks = 0, gDocUnique = 0, gDocBroken = 0, gDocBlocked = 0, gDocSummary = false;
var gRecent = [], gBackoffUntil = 0, gSiteI = 0, gSiteN = 0, gDoneCode = null;
// Re-check progress (runMode === "recheck"): re-uses gCrawled/gGood/gBroken/gBlocked as
// re-checked / now-OK / still-broken / now-blocked; gReTotal is how many were flagged to
// re-check (for the "K / N" readout) and gReStopped flags a re-check that was Stopped early.
var gReTotal = 0, gReStopped = false;
var gDiscoverPhase = false;  // set when discover emits "# discover start"; cleared on crawl start
// Reset only the live-log READ position + per-run control flags (NOT the tallies). Begin
// reading AFTER whatever is already in the live log, so a stale DONE_ marker (or stale
// progress lines) left by a previous run can't make this run misread a premature finish and
// stop at 0 (the AD-089 silent-failure class; writeFile(livePath, empty) truncates in the
// normal case, this is the backstop). Length is in CHARS to match readNew's Skip.
function resetReadState() {
  gPos = 0;
  try { if (livePath && fso.FileExists(livePath)) { var f0 = fso.OpenTextFile(livePath, 1, false); var pre0 = f0.AtEndOfStream ? "" : f0.ReadAll(); f0.Close(); gPos = pre0.length; } } catch (e0) { gPos = 0; }
  gBuf = ""; gTail = "";
  gRecent = []; gBackoffUntil = 0; gSiteI = 0; gSiteN = 0; gDoneCode = null;
  gReStopped = false; gDiscoverPhase = false;
}
// Zero the live tallies. Separate from resetReadState so a Rebuild (which regenerates the HTML
// from saved JSON and crawls nothing) can reset the read state to detect its DONE WITHOUT
// wiping the counters from the crawl/re-check the operator was just looking at.
function resetCounters() {
  gCrawled = 0; gGood = 0; gBroken = 0; gBlocked = 0;
  gExtFound = 0; gExtChecked = 0; gExtTotal = 0; gExtBad = 0;
  gDocs = 0; gDocLinks = 0; gDocUnique = 0; gDocBroken = 0; gDocBlocked = 0; gDocSummary = false;
  gReTotal = 0;
}
function resetLiveState() { resetReadState(); resetCounters(); }

function $(id) { return document.getElementById(id); }

// ---- locate this file's folder and crawl.js ----
function initPaths() {
  var p = String(window.location.pathname);     // e.g. /C:/Users/me/tools/crawl-gui.hta
  p = p.replace(/^[\/\\]+/, "");                 // strip leading slash
  try { p = decodeURIComponent(p); } catch (e) {}
  p = p.replace(/\//g, "\\");                    // to backslashes
  var slash = p.lastIndexOf("\\");
  scriptDir = (slash >= 0) ? p.substring(0, slash) : ".";
  jsPath = scriptDir + "\\crawl.js";
  renderPath = scriptDir + "\\crawl-render.js";
  $("workDir").value = scriptDir;
  if (!fso.FileExists(jsPath)) {
    setStatus("Could not find crawl.js next to this file (" + jsPath + "). Set it up first.", "bad");
  } else {
    setStatus("Ready. crawl.js found. Node.js must be on your PATH.", "muted");
  }
}

function setStatus(msg, cls) {
  var s = $("status");
  s.className = "status " + (cls || "muted");
  s.innerHTML = msg;
}

// ---- quoting / command building ----
function q(s) { return '"' + String(s).replace(/"/g, "") + '"'; }
function val(id) { return trim($(id).value); }
function trim(s) { return String(s).replace(/^\s+|\s+$/g, ""); }
// Pagination args from the page-size dropdown: "off" -> no paging; a number -> --paginate --page-size N.
function pushPageArgs(a) { var ps = $("pageSize").value; if (ps && ps !== "off") { a.push("--paginate"); a.push("--page-size " + q(ps)); } }

function buildArgs() {
  var a = [];
  var urls = getUrls();
  for (var u = 0; u < urls.length; u++) a.push(q(urls[u]));
  if ($("noPages").checked)      a.push("--max-pages none");
  else if (val("maxPages") !== "") a.push("--max-pages " + q(val("maxPages")));
  if ($("noDepth").checked)      a.push("--max-depth none");
  else if (val("maxDepth") !== "") a.push("--max-depth " + q(val("maxDepth")));
  var sc = $("scope").value;
  if (sc === "path") a.push("--scope path");
  else if (sc === "custom" && val("pathPrefix") !== "") a.push("--path-prefix " + q(val("pathPrefix")));
  if (val("concurrency") !== "") a.push("--concurrency " + q(val("concurrency")));
  if (val("delay") !== "")       a.push("--delay " + q(val("delay")));
  if (val("rps") !== "" && val("rps") !== "0") a.push("--rps " + q(val("rps")));
  if (val("timeout") !== "")     a.push("--timeout " + q(val("timeout")));
  if ($("includeSub").checked)   a.push("--include-subdomains");
  if ($("checkExternal").checked) a.push("--check-external");
  if (!$("recheck").checked)      a.push("--no-recheck");
  if (!$("scanDocs").checked)     a.push("--no-scan-docs");
  if ($("browser").checked)       a.push("--browser");
  pushPageArgs(a);
  if ($("allowlistExport").checked) a.push("--allowlist-export");
  // In browser mode, the default UA box means "use the built-in browser UA" — so
  // only pass --user-agent when it's non-empty AND not the unchanged default.
  var uaVal = val("userAgent");
  if (uaVal !== "" && !($("browser").checked && uaVal === "charlotte-crawler/1.0 (+local)")) a.push("--user-agent " + q(uaVal));
  if ($("seen").value !== "memory") a.push("--seen " + $("seen").value);
  if (val("allowlist") !== "")   a.push("--allowlist " + q(val("allowlist")));
  if (val("out") !== "")         a.push("--out " + q(val("out")));
  // Always write a JSON report (managed default if none given) so the "Re-check
  // broken links" button has a source to re-probe from.
  a.push("--json " + q(val("json") || "crawl-gui-report.json"));
  // The GUI tails this single (un-partitioned) progress log for live stats.
  a.push("--log " + q(val("log") || "crawl-gui-run.log"));
  a.push("--log-max-bytes 0");
  a.push("--state crawl-gui-state.jsonl");   // resume journal — lets the Resume button continue an interrupted crawl
  if (val("checkpoint") !== "")  a.push("--checkpoint " + q(val("checkpoint")));
  return a.join(" ");
}

function buildCommand() {
  return "node " + q(jsPath) + " " + buildArgs();
}

// ---- Discover (JS site): a two-step pipeline for JavaScript-built sites -------
// 1) crawl-render.js --discover renders each page in a real browser (Edge) and
//    harvests the links a client-side site (Laserfiche WebLink, SharePoint, most
//    document portals) builds with JavaScript — which the static crawl.js can't
//    see — writing them to a seeds file. 2) crawl.js --seeds then verifies those
//    links and scans the documents, in one report. Both steps use the live FORM
//    values (hence --no-config: the form is authoritative) and write to the same
//    progress log, so the GUI's live stats + Stop/Pause cover both phases.
var DISCOVER_SEEDS = "crawl-gui-discover.seeds.txt";
var DISCOVER_JSON  = "crawl-gui-discover.json";

function discoverOn() { return $("discoverJs") && $("discoverJs").checked; }

// Crawl-scope + pacing flags shared by the static crawl and the discover step.
function pushLimitArgs(a) {
  if ($("noPages").checked)        a.push("--max-pages none");
  else if (val("maxPages") !== "") a.push("--max-pages " + q(val("maxPages")));
  if ($("noDepth").checked)        a.push("--max-depth none");
  else if (val("maxDepth") !== "") a.push("--max-depth " + q(val("maxDepth")));
  var sc = $("scope").value;
  if (sc === "path") a.push("--scope path");
  else if (sc === "custom" && val("pathPrefix") !== "") a.push("--path-prefix " + q(val("pathPrefix")));
  if (val("concurrency") !== "") a.push("--concurrency " + q(val("concurrency")));
  if (val("delay") !== "")       a.push("--delay " + q(val("delay")));
  if (val("timeout") !== "")     a.push("--timeout " + q(val("timeout")));
  if ($("includeSub").checked)   a.push("--include-subdomains");
}

function buildDiscoverCommand() {
  var a = [], urls = getUrls();
  for (var u = 0; u < urls.length; u++) a.push(q(urls[u]));
  a.push("--discover");
  a.push("--no-config");          // the live form is authoritative — ignore crawl-gui-config.txt here
  pushLimitArgs(a);
  a.push("--channel msedge");     // the Edge that ships with Windows (no Chromium download)
  a.push("--ignore-case");        // WebLink/SharePoint/IIS: /Browse.aspx and /browse.aspx are one page
  a.push("--settle 2500");        // JS portals often finish rendering the folder AFTER networkidle; give late XHR a cushion so the listing exists before we harvest (discover is only used for JS sites, so the per-page cost is fine)
  if ($("laserfiche") && $("laserfiche").checked) a.push("--laserfiche");  // DocView.aspx docs -> file URLs, not rendered
  a.push("--seeds " + q(DISCOVER_SEEDS));
  a.push("--out " + q(DISCOVER_JSON));
  a.push("--log " + q(val("log") || "crawl-gui-run.log"));
  return "node " + q(renderPath) + " " + a.join(" ");
}

function buildVerifyCommand() {
  // crawl.js over the discovered seeds: verify links + scan documents, don't
  // re-crawl (depth 0) — the discover step already walked the tree.
  var a = ["--seeds " + q(DISCOVER_SEEDS), "--max-depth 0", "--max-pages none"];
  if (val("concurrency") !== "") a.push("--concurrency " + q(val("concurrency")));
  if (val("delay") !== "")       a.push("--delay " + q(val("delay")));
  if (val("rps") !== "" && val("rps") !== "0") a.push("--rps " + q(val("rps")));
  if (val("timeout") !== "")     a.push("--timeout " + q(val("timeout")));
  if ($("checkExternal").checked) a.push("--check-external");
  if (!$("recheck").checked)      a.push("--no-recheck");
  if (!$("scanDocs").checked)     a.push("--no-scan-docs");
  if ($("browser").checked)       a.push("--browser");
  pushPageArgs(a);
  if ($("allowlistExport").checked) a.push("--allowlist-export");
  if (val("allowlist") !== "")   a.push("--allowlist " + q(val("allowlist")));
  if (val("out") !== "")         a.push("--out " + q(val("out")));
  a.push("--json " + q(val("json") || "crawl-gui-report.json"));
  a.push("--log " + q(val("log") || "crawl-gui-run.log"));
  a.push("--log-max-bytes 0");
  return "node " + q(jsPath) + " " + a.join(" ");
}

// Command for "Re-check broken links": re-probe ONLY the flagged links from the last
// crawl's JSON, using the form's current network settings (rate, timeout, browser…).
// Not the crawl-scope settings — this re-checks links, it doesn't re-crawl.
function buildRecheckCommand() {
  var jsonName = val("json") || "crawl-gui-report.json";
  var a = ["--recheck-from " + q(jsonName)];
  var u0 = getUrls()[0];   // pass the Start URL so an OLD report (no recorded startUrl) keeps its host (apex vs www) instead of re-deriving it from the first crawled page
  if (u0) a.push("--start-url " + q(u0));
  if (val("concurrency") !== "") a.push("--concurrency " + q(val("concurrency")));
  if (val("delay") !== "")       a.push("--delay " + q(val("delay")));
  if (val("rps") !== "" && val("rps") !== "0") a.push("--rps " + q(val("rps")));
  if (val("timeout") !== "")     a.push("--timeout " + q(val("timeout")));
  if ($("browser").checked)      a.push("--browser");
  var uaVal = val("userAgent");
  if (uaVal !== "" && !($("browser").checked && uaVal === "charlotte-crawler/1.0 (+local)")) a.push("--user-agent " + q(uaVal));
  if (val("allowlist") !== "")   a.push("--allowlist " + q(val("allowlist")));
  if (val("out") !== "")         a.push("--out " + q(val("out")));
  pushPageArgs(a);
  if ($("allowlistExport").checked) a.push("--allowlist-export");
  a.push("--json " + q(jsonName));
  // Re-check writes its progress to this log so the GUI's live feed + counters update as it runs.
  a.push("--log " + q(val("log") || "crawl-gui-run.log"));
  a.push("--log-max-bytes 0");
  return "node " + q(jsPath) + " " + a.join(" ");
}

// Command for "Rebuild report": regenerate the HTML from the last crawl's JSON using
// this version's report features — no crawl, no network. Just data -> fresh HTML.
function buildRebuildCommand() {
  var jsonName = val("json") || "crawl-gui-report.json";
  var a = ["--rebuild-from " + q(jsonName)];
  var u0 = getUrls()[0];   // pass the Start URL so an OLD report (no recorded startUrl) keeps its host (apex vs www) instead of re-deriving it from the first crawled page
  if (u0) a.push("--start-url " + q(u0));
  if (val("allowlist") !== "") a.push("--allowlist " + q(val("allowlist")));
  if (val("out") !== "")       a.push("--out " + q(val("out")));
  pushPageArgs(a);
  if ($("allowlistExport").checked) a.push("--allowlist-export");
  a.push("--json " + q(jsonName));
  return "node " + q(jsPath) + " " + a.join(" ");
}

function updatePreview() {
  if (discoverOn()) {
    $("preview").innerHTML = escHtml(buildDiscoverCommand()) + "<br>&amp;&amp; " + escHtml(buildVerifyCommand());
  } else {
    $("preview").innerHTML = escHtml(buildCommand());
  }
}

// Browser-mode toggle. Note the User-Agent box: when browser mode is on and the
// box still holds the default value, the crawler substitutes a desktop-Chrome
// UA; type a custom UA to override it (it's still sent with browser headers).
function onBrowserToggle() { updatePreview(); }

// ---- Start URL rows (multiple sites, crawled sequentially) ----
function addUrlRow(value) {
  var wrap = document.createElement("div");
  wrap.className = "urlrow";
  var inp = document.createElement("input");
  inp.type = "text"; inp.className = "urlinput";
  inp.value = value || "https://";
  inp.onkeyup = updatePreview; inp.onchange = updatePreview;
  var rm = document.createElement("button");
  rm.className = "sec urlrm"; rm.type = "button"; rm.innerHTML = "&times;"; rm.title = "Remove this site";
  rm.onclick = function () {
    var rows = $("urlRows").getElementsByTagName("div");
    if (rows.length <= 1) { inp.value = "https://"; } // keep at least one row
    else { wrap.parentNode.removeChild(wrap); }
    updatePreview();
  };
  wrap.appendChild(inp); wrap.appendChild(rm);
  $("urlRows").appendChild(wrap);
  updatePreview();
}
function getUrls() {
  var ins = $("urlRows").getElementsByTagName("input"), urls = [];
  for (var i = 0; i < ins.length; i++) {
    var v = trim(ins[i].value);
    if (v !== "" && v !== "https://" && v !== "http://") urls.push(v);
  }
  return urls;
}

// ---- default Start URLs: pre-fill rows from an optional crawl-gui-domains.txt
//      next to this file (one URL per line; blank lines and lines starting with
//      # are ignored; an inline " # comment" after a URL is trimmed). Falls back
//      to a single empty row when the file is absent or empty. ----
function seedUrls() {
  var seeded = 0;
  try {
    var txt = readFile(scriptDir + "\\crawl-gui-domains.txt");
    if (txt !== "") {
      var lines = txt.split(/\r\n|\r|\n/);
      for (var i = 0; i < lines.length; i++) {
        var line = trim(lines[i]);
        if (line === "" || line.charAt(0) === "#") continue;
        var c = line.indexOf(" #");                 // strip an inline " # comment"
        if (c >= 0) line = trim(line.substring(0, c));
        if (line !== "") { addUrlRow(line); seeded++; }
      }
    }
  } catch (e) {}
  if (seeded === 0) addUrlRow("https://");           // keep the original single blank row
}

// ---- optional crawl-gui-config.txt next to this file: override the form defaults
//      (any field's saved default) without editing the GUI. One "key = value" per line;
//      key is a field id (e.g. maxPages, concurrency, delay, rps, timeout, pageSize (off/250/500/1000/2500/5000),
//      discoverJs, laserfiche, checkExternal, browser, scanDocs, recheck, includeSub, noPages, noDepth, scope,
//      pathPrefix, seen, allowlist, allowlistExport, out, json, log, checkpoint, userAgent, workDir).
//      Checkboxes take true/false (or 1/0, yes/no, on/off). '#' starts a comment; blank
//      lines ignored. Unknown keys are skipped. (Start URLs come from crawl-gui-domains.txt.)
function loadGuiConfig() {
  var applied = 0;
  try {
    var txt = readFile(scriptDir + "\\crawl-gui-config.txt");
    if (txt === "") return 0;
    var lines = txt.split(/\r\n|\r|\n/);
    for (var i = 0; i < lines.length; i++) {
      var line = trim(lines[i]);
      if (line === "" || line.charAt(0) === "#") continue;
      var eq = line.indexOf("=");
      if (eq < 0) continue;
      var key = trim(line.substring(0, eq));
      var v = trim(line.substring(eq + 1));
      var c = v.indexOf(" #");                       // strip an inline " # comment"
      if (c >= 0) v = trim(v.substring(0, c));
      var el = $(key);
      if (!el) continue;                             // unknown field id — skip
      if (el.type === "checkbox") el.checked = /^(1|true|yes|on)$/i.test(v);
      else el.value = v;                             // text input or <select>
      applied++;
    }
  } catch (e) {}
  return applied;
}

// Enable/disable dependent fields: "no limit" greys out the depth box, and the
// custom path-prefix row only shows when scope is "custom".
function toggleInputs() {
  $("maxDepth").disabled = $("noDepth").checked;
  $("maxPages").disabled = $("noPages").checked;
  var sc = $("scope").value;
  $("pathPrefix").disabled = (sc !== "custom");
  $("prefixRow").style.display = (sc === "custom") ? "" : "none";
}

function escHtml(s) {
  return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
}

// ---- run ----
function startCrawl(resume) {
  if (running) return;
  if (getUrls().length === 0) {
    setStatus("Enter at least one start URL.", "bad"); return;
  }
  if (!fso.FileExists(jsPath)) { setStatus("crawl.js not found at " + jsPath, "bad"); return; }
  if (resume && !journalExists()) { setStatus("No saved crawl to resume — run a crawl first.", "bad"); return; }
  runMode = "crawl";
  var workDir = val("workDir") || scriptDir;
  if (!fso.FolderExists(workDir)) { setStatus("Output folder does not exist: " + workDir, "bad"); return; }

  // All helper files go in the OUTPUT folder (managed machines often block
  // %TEMP%). We tail the crawler's OWN progress log (livePath) — it's written
  // with per-line appends, so it reads reliably while the crawl runs, unlike a
  // file held open by a shell redirect.
  var logName = val("log") || "crawl-gui-run.log";
  livePath = isAbsolute(logName) ? logName : (workDir + "\\" + logName);
  errPath  = workDir + "\\crawl-gui-err.log";
  batPath  = workDir + "\\crawl-gui-run.bat";
  stopPath = workDir + "\\crawl-gui-stop.flag";
  pausePath = workDir + "\\crawl-gui-pause.flag";
  tunePath = workDir + "\\crawl-gui-tune.json";
  // Neutralize a stale Stop/Pause flag BEFORE the bat embeds these paths, so a
  // leftover flag (e.g. from a prior Stop click that deleteIfExists couldn't
  // clear) can't make this run stop at 0. See freshFlag.
  stopPath = freshFlag(stopPath, "stop");
  pausePath = freshFlag(pausePath, "pause");

  // The batch runs node (with control files), sends node's own console to the
  // err log, and appends a DONE_<exitcode> marker to the live log we poll.
  var bat = "";
  bat += "@echo off\r\n";
  bat += "cd /d " + q(workDir) + "\r\n";
  if (discoverOn()) {
    // Two steps: render-and-harvest (crawl-render.js), then verify+scan the seeds
    // (crawl.js). If the discover step fails, mark DONE and stop before verify.
    if (!fso.FileExists(renderPath)) {
      setStatus("“Discover (JS site)” is on but crawl-render.js wasn't found next to this file (" + renderPath +
        "). Uncheck it for a plain static crawl, or add crawl-render.js.", "bad");
      return;
    }
    var discCmd = buildDiscoverCommand() + " --stop-file " + q(stopPath) + " --pause-file " + q(pausePath);
    var verCmd  = buildVerifyCommand()  + " --stop-file " + q(stopPath) + " --pause-file " + q(pausePath) + " --tune-file " + q(tunePath);
    bat += discCmd + " > " + q(errPath) + " 2>&1\r\n";
    bat += "if errorlevel 1 echo DONE_%ERRORLEVEL%>> " + q(livePath) + "\r\n";
    bat += "if errorlevel 1 goto :CWDONE\r\n";
    bat += verCmd + " >> " + q(errPath) + " 2>&1\r\n";
    bat += "echo DONE_%ERRORLEVEL%>> " + q(livePath) + "\r\n";
    bat += ":CWDONE\r\n";
  } else {
    var runCmd = buildCommand() +
      " --stop-file " + q(stopPath) + " --pause-file " + q(pausePath) + " --tune-file " + q(tunePath) +
      (resume ? " --resume crawl-gui-state.jsonl" : "");
    bat += runCmd + " > " + q(errPath) + " 2>&1\r\n";
    bat += "echo DONE_%ERRORLEVEL%>> " + q(livePath) + "\r\n";
  }

  try {
    deleteIfExists(tunePath);   // start clean so stale tune values can't carry over
    deleteIfExists(errPath);    // clear old error log so the errPath fallback in liveout shows fresh content
    writeFile(livePath, "");    // fresh live log: truncate/create-empty (deleteIfExists silently fails on locked files, leaving a stale DONE_ that triggers a false instant-finish on the next run)
    writeFile(batPath, bat);
  } catch (e) {
    setStatus("Couldn't write helper files to " + workDir + " — " + e.message +
      ". Pick an output folder you can write to, or click “Copy command” and run it in a terminal.", "bad");
    return;
  }

  showTab("run");          // jump to the Run tab so the live log is visible
  $("liveout").value = "Launching crawler… live progress will appear here as pages are crawled.";
  $("recent").innerHTML = "";
  $("startBtn").disabled = true;
  $("recheckBtn").disabled = true;
  $("rebuildBtn").disabled = true;
  $("resumeBtn").disabled = true;
  $("pauseBtn").disabled = false;
  $("pauseBtn").innerHTML = "Pause";
  $("stopBtn").disabled = false;
  running = true;
  isPaused = false;
  startMs = new Date().getTime();
  lastCount = 0;
  lastChangeMs = startMs;
  resetLiveState();
  $("statsBar").style.display = "";
  $("recentBox").style.display = "";
  $("statCount").innerHTML = "0";
  $("statGood").innerHTML = "0";
  $("statBroken").innerHTML = "0";
  $("statTime").innerHTML = "0:00";
  $("statRate").innerHTML = "0";
  setActivity("starting&hellip;", false);
  setStatus("Crawling… (live stats below)", "muted");

  // Launch hidden + async; we tail the live log ourselves.
  try {
    shell.Run('cmd /c ""' + batPath + '""', 0, false);
  } catch (e) {
    running = false;
    $("startBtn").disabled = false;
    $("pauseBtn").disabled = true;
    $("stopBtn").disabled = true;
    setActivity("error", true);
    setStatus("Couldn't launch the crawl — " + e.message +
      ". Click “Copy command” and run it in a terminal instead.", "bad");
    return;
  }
  timer = window.setInterval(poll, 500);
}

// Re-check ONLY the broken links from the last crawl's JSON, with the current form
// settings. Reuses the same launch + DONE-marker + poll machinery as a crawl, including
// live counters (re-checked / now OK / still broken / blocked) and the Pause/Stop buttons.
function recheckLinks() {
  if (running) return;
  if (!fso.FileExists(jsPath)) { setStatus("crawl.js not found at " + jsPath, "bad"); return; }
  var workDir = val("workDir") || scriptDir;
  if (!fso.FolderExists(workDir)) { setStatus("Output folder does not exist: " + workDir, "bad"); return; }
  var jsonName = val("json") || "crawl-gui-report.json";
  var jsonAbs = isAbsolute(jsonName) ? jsonName : (workDir + "\\" + jsonName);
  if (!fso.FileExists(jsonAbs)) { setStatus("No report JSON to re-check yet (" + jsonName + "). Run a crawl first — it writes one automatically.", "bad"); return; }

  var logName = val("log") || "crawl-gui-run.log";
  livePath = isAbsolute(logName) ? logName : (workDir + "\\" + logName);
  errPath  = workDir + "\\crawl-gui-err.log";
  batPath  = workDir + "\\crawl-gui-run.bat";
  stopPath = workDir + "\\crawl-gui-stop.flag";
  pausePath = workDir + "\\crawl-gui-pause.flag";
  tunePath = "";   // live re-tuning isn't supported during re-check — keep togglePause's writeTune a no-op
  stopPath = freshFlag(stopPath, "stop");     // neutralize a stale, locked flag before it's embedded in the bat (would halt at 0)
  pausePath = freshFlag(pausePath, "pause");

  // Re-check honors the same Stop/Pause control files as a crawl, so those buttons work here too.
  var runCmd = buildRecheckCommand() + " --stop-file " + q(stopPath) + " --pause-file " + q(pausePath);
  var bat = "@echo off\r\ncd /d " + q(workDir) + "\r\n" + runCmd + " > " + q(errPath) + " 2>&1\r\necho DONE_%ERRORLEVEL%>> " + q(livePath) + "\r\n";
  try { deleteIfExists(errPath); writeFile(livePath, ""); writeFile(batPath, bat); }
  catch (e) { setStatus("Couldn't write helper files to " + workDir + " — " + e.message + ". Click “Copy command” and run it in a terminal.", "bad"); return; }

  runMode = "recheck";
  showTab("run");
  $("liveout").value = "Re-checking the broken links from the last crawl with the current settings…";
  $("recent").innerHTML = "";
  $("startBtn").disabled = true; $("recheckBtn").disabled = true; $("rebuildBtn").disabled = true; $("resumeBtn").disabled = true;
  $("pauseBtn").disabled = false; $("pauseBtn").innerHTML = "Pause"; $("stopBtn").disabled = false;
  running = true; isPaused = false; startMs = new Date().getTime(); lastCount = 0; lastChangeMs = startMs;
  resetLiveState();
  $("statsBar").style.display = ""; $("recentBox").style.display = "";
  $("statCount").innerHTML = "0"; $("statGood").innerHTML = "0"; $("statBroken").innerHTML = "0"; $("statTime").innerHTML = "0:00"; $("statRate").innerHTML = "0";
  setActivity("re-checking links&hellip;", false);
  setStatus("Re-checking broken links with the current settings…", "muted");
  try { shell.Run('cmd /c ""' + batPath + '""', 0, false); }
  catch (e) { running = false; $("startBtn").disabled = false; $("recheckBtn").disabled = false; setActivity("error", true); setStatus("Couldn't launch re-check — " + e.message + ". Use “Copy command”.", "bad"); return; }
  timer = window.setInterval(poll, 500);
}

// Rebuild the HTML report from the last crawl's JSON (no re-crawl) — to apply new
// report features to an old crawl's data.
function rebuildReport() {
  if (running) return;
  if (!fso.FileExists(jsPath)) { setStatus("crawl.js not found at " + jsPath, "bad"); return; }
  var workDir = val("workDir") || scriptDir;
  if (!fso.FolderExists(workDir)) { setStatus("Output folder does not exist: " + workDir, "bad"); return; }
  var jsonName = val("json") || "crawl-gui-report.json";
  var jsonAbs = isAbsolute(jsonName) ? jsonName : (workDir + "\\" + jsonName);
  if (!fso.FileExists(jsonAbs)) { setStatus("No report JSON to rebuild from (" + jsonName + "). Run a crawl first — it writes one automatically.", "bad"); return; }

  var logName = val("log") || "crawl-gui-run.log";
  livePath = isAbsolute(logName) ? logName : (workDir + "\\" + logName);
  errPath  = workDir + "\\crawl-gui-err.log";
  batPath  = workDir + "\\crawl-gui-run.bat";

  var bat = "@echo off\r\ncd /d " + q(workDir) + "\r\n" + buildRebuildCommand() + " > " + q(errPath) + " 2>&1\r\necho DONE_%ERRORLEVEL%>> " + q(livePath) + "\r\n";
  try { deleteIfExists(errPath); writeFile(livePath, ""); writeFile(batPath, bat); }
  catch (e) { setStatus("Couldn't write helper files to " + workDir + " — " + e.message + ". Click “Copy command” and run it in a terminal.", "bad"); return; }

  runMode = "rebuild";
  showTab("run");
  $("liveout").value = "Rebuilding the HTML report from the last crawl's data…";
  $("recent").innerHTML = "";
  $("startBtn").disabled = true; $("recheckBtn").disabled = true; $("resumeBtn").disabled = true; $("rebuildBtn").disabled = true;
  $("pauseBtn").disabled = true; $("stopBtn").disabled = true;
  running = true; isPaused = false; startMs = new Date().getTime(); lastCount = 0; lastChangeMs = startMs;
  resetReadState();   // reset only the log-read state to catch this rebuild's DONE; a rebuild crawls nothing, so the live counters are left exactly as they were
  setActivity("rebuilding report&hellip;", false);
  setStatus("Rebuilding the report from existing data — no re-crawl…", "muted");
  try { shell.Run('cmd /c ""' + batPath + '""', 0, false); }
  catch (e) { running = false; $("startBtn").disabled = false; $("recheckBtn").disabled = false; $("rebuildBtn").disabled = false; setActivity("error", true); setStatus("Couldn't launch rebuild — " + e.message + ". Use “Copy command”.", "bad"); return; }
  timer = window.setInterval(poll, 500);
}

function isAbsolute(p) { return /^[A-Za-z]:\\/.test(p) || p.indexOf("\\\\") === 0; }
function deleteIfExists(p) { try { if (fso.FileExists(p)) fso.DeleteFile(p); } catch (e) {} }
// Clear a stale Stop/Pause flag before a run. If it can't be removed -- OneDrive
// sync, antivirus, or a still-running crawl can lock the file, and deleteIfExists
// swallows the failure (the AD-089 silent-deleteIfExists class) -- a leftover flag
// makes the next run halt at 0 immediately. So if the flag survives deletion,
// switch THIS run to a uniquely-named flag the stale one can't shadow. tag keeps
// the stop vs pause names distinct within one run.
function freshFlag(p, tag) {
  deleteIfExists(p);
  if (fso.FileExists(p)) return workDir + "\\crawl-gui-" + tag + "." + (new Date()).getTime() + ".flag";
  return p;
}
// True when a resume journal (crawl-gui-state*.jsonl) from a continuable crawl exists.
function journalExists() {
  try {
    var workDir = val("workDir") || scriptDir;
    if (!fso.FolderExists(workDir)) return false;
    var en = new Enumerator(fso.GetFolder(workDir).Files);
    for (; !en.atEnd(); en.moveNext()) { if (/^crawl-gui-state.*\.jsonl$/i.test(String(en.item().Name))) return true; }
  } catch (e) {}
  return false;
}
function updateResumeBtn() { if ($("resumeBtn")) $("resumeBtn").disabled = (running || !journalExists()); }

// ---- Stop / Pause via control files (the crawler watches for these) ----
function stopCrawl() {
  if (!running) return;
  try { writeFile(stopPath, ""); }
  catch (e) { setStatus("Couldn't write stop file — " + e.message, "bad"); return; }
  $("stopBtn").disabled = true;
  $("pauseBtn").disabled = true;
  setActivity("stopping&hellip;", true);
  setStatus("Stopping — the crawler is writing a partial report…", "muted");
}
function togglePause() {
  if (!running) return;
  if (!isPaused) {
    try { writeFile(pausePath, ""); }
    catch (e) { setStatus("Couldn't write pause file — " + e.message, "bad"); return; }
    isPaused = true;
    $("pauseBtn").innerHTML = "Resume";
    setActivity("paused", true);
    setStatus("Paused — click Resume to continue.", "muted");
  } else {
    writeTune();              // apply any changed Delay / Max req-sec / Timeout on resume
    deleteIfExists(pausePath);
    isPaused = false;
    $("pauseBtn").innerHTML = "Pause";
    setActivity("resuming&hellip;", false);
    setStatus("Crawling… (live settings applied)", "muted");
  }
}

// Write the live-tunable rate fields to the tune file the running crawler watches.
// Called on Resume so a changed Delay / Max req-sec / Timeout takes effect WITHOUT
// restarting. Only delay/rps/timeout are hot-swappable; other settings need a
// Stop + Resume crawl (which continues without re-crawling).
function numField(id) { var v = val(id); if (v === "") return null; var n = parseFloat(v); return isNaN(n) ? null : n; }
function writeTune() {
  if (!tunePath) return;
  var parts = [];
  var d = numField("delay"); if (d !== null) parts.push('"delay":' + d);
  var r = numField("rps"); if (r !== null) parts.push('"rps":' + r);
  var t = numField("timeout"); if (t !== null) parts.push('"timeout":' + t);
  try { writeFile(tunePath, "{" + parts.join(",") + "}"); } catch (e) {}
}

// mm:ss from whole seconds.
function fmtTime(secs) {
  var m = Math.floor(secs / 60), s = secs % 60;
  return m + ":" + (s < 10 ? "0" + s : s);
}

function setActivity(html, warn) {
  var a = $("statActivity");
  a.innerHTML = html;
  a.className = warn ? "statchip warn" : "statchip";
}

// Seconds of no progress before the "no new page" warning. Adaptive, not a fixed
// 10s: a single request can legitimately take up to the configured Timeout, then
// the inter-request Delay, then more for a slow multi-MB document download (whose
// streaming keeps resetting the timeout). So scale the threshold with those
// settings — a deliberately polite, document-heavy crawl shouldn't look "stuck".
function stallSecs() {
  var t = parseInt(val("timeout"), 10); if (!(t > 0)) t = 20000;
  var d = parseInt(val("delay"), 10); if (!(d >= 0)) d = 0;
  return Math.max(20, Math.ceil((t + d * 2) / 1000) + 15);
}

// Parse the crawler's progress log for live stats. Lines look like
//   "<ISO> OK d0 200 http://… int=4 ext=1"   (a good page)
//   "<ISO> ERR http://… :: HTTP 404"          (a broken one)
//   "<ISO> SKIP http://… :: text/…"           (non-HTML, skipped)
// plus "# …" markers and a trailing "DONE_<code>".
function progressPages(text) {
  var lines = text.split(/\r?\n/);
  var pages = [], broken = 0, good = 0;
  for (var i = 0; i < lines.length; i++) {
    var m = lines[i].match(/^\S+\s+(OK|ERR|SKIP)\s+(.*)$/);
    if (!m) continue;
    pages.push(m[1] + "  " + m[2]);
    if (m[1] === "ERR") broken++;
    else if (m[1] === "OK") good++;
  }
  pages.broken = broken;
  pages.good = good;
  return pages;
}

// Latest "# BACKOFF … untilMs=<epoch>" marker, so the GUI can show a live
// rate-limit countdown instead of a misleading "stuck" warning.
function lastBackoffUntil(text) {
  var re = /# BACKOFF [^\n]*untilMs=(\d+)/g, m, last = 0;
  while ((m = re.exec(text)) !== null) last = parseInt(m[1], 10);
  return last;
}
// Last single-capture int / last pair of ints matching a /g regex.
function lastInt(re, text) { var m, last = null; while ((m = re.exec(text)) !== null) last = parseInt(m[1], 10); return last; }
function lastPair(re, text) { var m, last = null; while ((m = re.exec(text)) !== null) last = [parseInt(m[1], 10), parseInt(m[2], 10)]; return last; }

// Read only the NEW bytes of the log since last poll (FSO Skip), so a multi-MB
// log isn't re-read and re-parsed every tick.
function readNew(path) {
  try {
    if (!fso.FileExists(path)) return "";
    var f = fso.OpenTextFile(path, 1, false);
    if (gPos > 0) { try { f.Skip(gPos); } catch (e) {} }
    var t = f.AtEndOfStream ? "" : f.ReadAll();
    f.Close();
    gPos += t.length;
    return t;
  } catch (e) { return ""; }
}

// Update running counters from one log line.
function processLine(ln) {
  ln = ln.replace(/\r$/, "");
  if (ln === "") return;
  var dm = ln.match(/^DONE_(\-?\d+)/);
  if (dm) { gDoneCode = parseInt(dm[1], 10); return; }
  if (ln.indexOf("# discover start ") === 0) { gDiscoverPhase = true; return; }
  if (ln.indexOf("# crawl start ") === 0) { gDiscoverPhase = false; return; }
  var m = ln.match(/^\S+\s+(OK|ERR|SKIP|BLOCKED)\s+(.*)$/);
  if (m) {
    gCrawled++;
    if (m[1] === "OK") gGood++; else if (m[1] === "ERR") gBroken++; else if (m[1] === "BLOCKED") gBlocked++;
    var et = ln.match(/extTotal=(\d+)/); if (et) gExtFound = parseInt(et[1], 10);
    gRecent.push(m[1] + "  " + m[2]); if (gRecent.length > 5) gRecent.shift();
    lastChangeMs = (new Date()).getTime();
    return;
  }
  // On resume the crawler replays its journal silently into a fresh log, so seed the live
  // counters with what was already done. ADD (don't set) so multi-site resumes accumulate;
  // external is an absolute total (like extTotal=) so it's set.
  var rs = ln.match(/^# resume-stats crawled=(\d+) good=(\d+) broken=(\d+) blocked=(\d+) external=(\d+)/);
  if (rs) { gCrawled += parseInt(rs[1], 10); gGood += parseInt(rs[2], 10); gBroken += parseInt(rs[3], 10); gBlocked += parseInt(rs[4], 10); gExtFound = parseInt(rs[5], 10); return; }
  // Document scanning: one # docscan per scanned document (live count of docs +
  // link instances inside them); one final # docsummary with unique/broken/blocked.
  var dsc = ln.match(/^# docscan links=(\d+)/);
  if (dsc) { if (!gDocSummary) { gDocs++; gDocLinks += parseInt(dsc[1], 10); } return; }
  var dsm = ln.match(/^# docsummary docs=(\d+) instances=(\d+) unique=(\d+) broken=(\d+) blocked=(\d+)/);
  if (dsm) { gDocs = parseInt(dsm[1], 10); gDocLinks = parseInt(dsm[2], 10); gDocUnique = parseInt(dsm[3], 10); gDocBroken = parseInt(dsm[4], 10); gDocBlocked = parseInt(dsm[5], 10); gDocSummary = true; return; }
  // Re-check progress (--recheck-from). Lowercase verdict tokens so these never match the crawl
  // "URL OK/ERR/…" regex above; they re-use the crawl counters with re-check meaning.
  var rst = ln.match(/^# recheck-start total=(\d+)/);
  if (rst) { gReTotal += parseInt(rst[1], 10); return; }
  var rk = ln.match(/^RECHK (ok|broken|blocked) (.*)$/);
  if (rk) {
    gCrawled++;
    if (rk[1] === "ok") gGood++; else if (rk[1] === "broken") gBroken++; else gBlocked++;
    gRecent.push(rk[1] + "  " + rk[2]); if (gRecent.length > 5) gRecent.shift();
    lastChangeMs = (new Date()).getTime();
    return;
  }
  if (ln.indexOf("# recheck-done") === 0) { if (/ stopped=1/.test(ln)) gReStopped = true; return; }
  var ex = ln.match(/^# extcheck (\d+)\/(\d+) (\w+)/);
  if (ex) { gExtChecked = parseInt(ex[1], 10); gExtTotal = parseInt(ex[2], 10); if (ex[3] === "err") gExtBad++; else if (ex[3] === "blocked") gBlocked++; return; }
  var bo = ln.match(/untilMs=(\d+)/); if (ln.indexOf("# BACKOFF") === 0 && bo) { gBackoffUntil = parseInt(bo[1], 10); return; }
  var sm = ln.match(/^# === site (\d+)\/(\d+)/); if (sm) { gSiteI = parseInt(sm[1], 10); gSiteN = parseInt(sm[2], 10); return; }
}

function poll() {
  var chunk = readNew(livePath);
  if (chunk !== "") {
    gBuf += chunk;
    var lines = gBuf.split(/\n/);
    gBuf = lines.pop();                 // keep trailing partial line for next read
    for (var i = 0; i < lines.length; i++) processLine(lines[i]);
    // tail buffer for the live-log textarea (cap so it never grows unbounded)
    gTail += chunk; if (gTail.length > 60000) gTail = gTail.substring(gTail.length - 60000);
    var disp = gTail.replace(/DONE_(\-?\d+)\s*$/, "");
    if (disp.replace(/\s/g, "") === "") { var efb = readFile(errPath); if (efb !== "") disp = efb; }
    $("liveout").value = disp;
    $("liveout").scrollTop = $("liveout").scrollHeight;
  }
  // DONE may arrive on the still-partial last line:
  if (gDoneCode === null) { var dm = gBuf.match(/DONE_(\-?\d+)/); if (dm) gDoneCode = parseInt(dm[1], 10); }

  var now = (new Date()).getTime();
  var secs = Math.floor((now - startMs) / 1000);
  // A rebuild crawls nothing and regenerates HTML from the saved JSON — leave the stat chips,
  // timer and recent box exactly as the prior crawl/re-check left them (don't reset to 0).
  if (runMode !== "rebuild") {
  if (runMode === "recheck") {
    // Same chips, re-check meaning: re-checked K/N · now OK · still broken · now blocked.
    $("lblCount").innerHTML = "Re-checked";  $("statCount").innerHTML = gReTotal ? (gCrawled + " / " + gReTotal) : gCrawled;
    $("lblGood").innerHTML = "Now OK";       $("statGood").innerHTML = gGood;
    $("lblBroken").innerHTML = "Still broken"; $("statBroken").innerHTML = gBroken;
    $("brokenChip").className = gBroken > 0 ? "statchip warn" : "statchip";
    $("lblBlocked").innerHTML = "Now blocked"; $("statBlocked").innerHTML = gBlocked;
    $("blockedChip").className = gBlocked > 0 ? "statchip warn" : "statchip";
    $("extChip").style.display = "none";
    $("statRate").innerHTML = secs > 0 ? Math.round(gCrawled / secs * 60) : 0;
  } else {
    $("lblCount").innerHTML = "Crawled";     $("statCount").innerHTML = gCrawled;
    $("lblGood").innerHTML = "Good";         $("statGood").innerHTML = gGood;
    $("lblBroken").innerHTML = "Broken (internal)"; $("statBroken").innerHTML = gBroken;
    $("brokenChip").className = gBroken > 0 ? "statchip warn" : "statchip";
    $("lblBlocked").innerHTML = "Blocked/uncertain"; $("statBlocked").innerHTML = gBlocked;
    $("blockedChip").className = gBlocked > 0 ? "statchip warn" : "statchip";
    $("extChip").style.display = "";
    // Rate counts every request — pages AND external checks.
    $("statRate").innerHTML = secs > 0 ? Math.round((gCrawled + gExtChecked) / secs * 60) : 0;
    if (gExtChecked > 0) {
      $("extChip").innerHTML = "External: <b>" + gExtChecked + "/" + gExtTotal + "</b> verified" + (gExtBad ? " · <b>" + gExtBad + "</b> broken" : "");
      $("extChip").className = gExtBad ? "statchip warn" : "statchip";
    } else {
      $("extChip").innerHTML = "External: <b>" + gExtFound + "</b> found";
      $("extChip").className = "statchip";
    }
    // Documents badge: "Docs: N · M links" live, gaining "· U dest · K broken · B blocked" at the end.
    $("statDocs").innerHTML = gDocs;
    $("statDocLinks").innerHTML = gDocLinks;
    $("statDocBad").innerHTML = gDocSummary
      ? (" · <b>" + gDocUnique + "</b> dest" + (gDocBroken ? " · <b>" + gDocBroken + "</b> broken" : "") + (gDocBlocked ? " · <b>" + gDocBlocked + "</b> blocked" : ""))
      : "";
    $("docChip").className = (gDocSummary && gDocBroken) ? "statchip warn" : "statchip";
  }
  $("statTime").innerHTML = fmtTime(secs);
  $("recent").innerHTML = escHtml(gRecent.join("\n"));
  $("recent").scrollTop = $("recent").scrollHeight;
  }

  var done = (gDoneCode !== null);
  if (!done && runMode === "rebuild") {
    setActivity("rebuilding report&hellip;", false);
  } else if (!done && runMode === "recheck") {
    if (isPaused) setActivity("paused", true);
    else setActivity("re-checking links " + (gReTotal ? (gCrawled + "/" + gReTotal) : gCrawled) + "&hellip;", false);
  } else if (!done) {
    var siteTag = gSiteN ? " (site " + gSiteI + "/" + gSiteN + ")" : "";
    if (isPaused) setActivity("paused" + siteTag, true);
    else if (gBackoffUntil > now) setActivity("rate limited — auto-resume in " + Math.ceil((gBackoffUntil - now) / 1000) + "s" + siteTag, true);
    else if (gExtTotal > 0 && gExtChecked < gExtTotal) setActivity("verifying external links " + gExtChecked + "/" + gExtTotal + siteTag, false);
    else {
      var idle = Math.floor((now - lastChangeMs) / 1000);
      var stall = stallSecs();
      if (gCrawled === 0 && secs >= stall) setActivity((gDiscoverPhase ? "browser rendering, waiting for first page" : "waiting for first page") + "&hellip; (" + secs + "s)" + siteTag, true);
      else if (idle >= stall) setActivity("no new page in " + idle + "s — may be stuck or rate-limited" + siteTag, true);
      else if (gDiscoverPhase) setActivity("discovering JS links&hellip;" + siteTag, false);
      else setActivity("crawling&hellip;" + siteTag, false);
    }
  } else {
    window.clearInterval(timer); timer = null; running = false; isPaused = false;
    $("startBtn").disabled = false;
    $("recheckBtn").disabled = false; $("rebuildBtn").disabled = false;
    updateResumeBtn();
    $("pauseBtn").disabled = true; $("pauseBtn").innerHTML = "Pause";
    $("stopBtn").disabled = true;
    deleteIfExists(stopPath); deleteIfExists(pausePath);
    if (gDoneCode === 0) {
      $("reportBtn").disabled = false;
      if (runMode === "recheck") {
        var rsum = gCrawled + " re-checked · " + gGood + " now OK · " + gBlocked + " blocked · " + gBroken + " still broken";
        if (gReStopped) {
          setActivity("stopped", false);
          setStatus("Re-check stopped — " + rsum + ". The report was updated with the links checked so far (the rest are kept as broken). Click “Open crawl report”.", "muted");
        } else {
          setActivity("finished", false);
          setStatus("Re-check complete — " + rsum + ". The report’s broken-link list has been updated. Click “Open crawl report”.", "ok");
        }
      } else if (runMode === "rebuild") { setActivity("finished", false); setStatus("Report rebuilt from existing data — this version's report features are now applied. Click “Open crawl report”.", "ok"); }
      else { setActivity("finished", false); setStatus("Done — " + gCrawled + " crawled (" + gGood + " good, " + gBroken + " broken" + (gBlocked ? ", " + gBlocked + " blocked/uncertain" : "") + ") in " + fmtTime(secs) + ". Click “Open crawl report”.", "ok"); }
    } else if (gDoneCode === 130) {
      $("reportBtn").disabled = false;
      setActivity("stopped", false);
      setStatus("Stopped after " + gCrawled + " pages — a partial report was written. Click “Open crawl report”.", "muted");
    } else {
      setActivity("error", true);
      var err = readFile(errPath);
      if (err !== "") $("liveout").value = err;
      var hint = (gDoneCode === 9009 || /not recognized|is not recognized/i.test(err))
        ? " — Node.js wasn't found. Install it from nodejs.org and reopen this window."
        : ". Click “Copy command” and run it in a terminal to see the full error.";
      setStatus("Finished with errors (exit code " + gDoneCode + ")" + hint, "bad");
    }
  }
}

// ---- file helpers ----
function writeFile(path, content) {
  var f = fso.OpenTextFile(path, 2, true);   // 2 = write, create if missing
  f.Write(content);
  f.Close();
}
function readFile(path) {
  try {
    if (!fso.FileExists(path)) return "";
    var f = fso.OpenTextFile(path, 1, false); // 1 = read
    var t = f.AtEndOfStream ? "" : f.ReadAll();
    f.Close();
    return t;
  } catch (e) { return ""; }
}

// ---- buttons ----
function reportPath() {
  var workDir = val("workDir") || scriptDir;
  var out = val("out") || "crawl-report.html";
  // absolute path? leave as-is, else join with workDir
  if (/^[A-Za-z]:\\/.test(out) || out.indexOf("\\") === 0) return out;
  return workDir + "\\" + out;
}
function openReport() {
  var rp = reportPath();
  if (!fso.FileExists(rp)) {
    setStatus(running
      ? "Report is being written — try again in a second."
      : "No report yet at " + rp + ". Run a crawl first.", "muted");
    return;
  }
  // While running, the report is the partial one and auto-refreshes in the browser.
  shell.Run(q(rp), 1, false);
  if (running) setStatus("Opened the live partial report — it refreshes every 5s as the crawl runs.", "muted");
}
function openFolder() {
  var workDir = val("workDir") || scriptDir;
  shell.Run("explorer.exe " + q(workDir), 1, false);
}
function copyCommand() {
  try {
    window.clipboardData.setData("Text", buildCommand());
    setStatus("Command copied to clipboard.", "ok");
  } catch (e) {
    setStatus("Copy failed — select the preview text manually.", "bad");
  }
}

// Show unexpected script errors as a friendly status line instead of the raw
// "Script Error / continue running scripts?" dialog.
window.onerror = function (msg, url, line) {
  try {
    if (running) { running = false; if (timer) { window.clearInterval(timer); timer = null; } }
    $("startBtn").disabled = false;
    $("pauseBtn").disabled = true; $("pauseBtn").innerHTML = "Pause";
    $("stopBtn").disabled = true;
    setStatus("Unexpected error: " + msg + " (line " + line + "). If launching, use “Copy command” and run it in a terminal.", "bad");
  } catch (e) {}
  return true; // suppress the default error dialog
};

// Switch between the Settings and Run tabs (purely show/hide; no run state touched).
function showTab(name) {
  var t = ["settings", "run"], i;
  for (i = 0; i < t.length; i++) {
    var on = (t[i] === name);
    var p = $("tab-" + t[i]); if (p) p.className = on ? "tabpanel active" : "tabpanel";
    var b = $("tabbtn-" + t[i]); if (b) b.className = on ? "tabbtn active" : "tabbtn";
  }
}

// On open the HTA otherwise picks a giant default width. Size it to the content instead:
// measure the natural width of BOTH tab panels at once (an off-screen clone with both panels
// shown and the stretchy width:100% elements neutralized so they can't inflate it), then resize
// the window width to fit. Adaptive — it follows whatever the interface actually needs, so layout
// changes don't need a new magic number. Width only; height is left as-is. Best-effort: if anything
// fails the window just keeps its default size.
function fitWindowWidth() {
  try {
    var w = $("wrap"); if (!w) return;
    var c = w.cloneNode(true); c.id = "";
    c.style.position = "absolute"; c.style.left = "-99999px"; c.style.top = "0px";
    c.style.display = "inline-block"; c.style.width = "auto";
    var i, pnls = c.getElementsByTagName("div");
    for (i = 0; i < pnls.length; i++) { if ((" " + pnls[i].className + " ").indexOf(" tabpanel ") >= 0) pnls[i].className = "tabpanel active"; }
    var tbls = c.getElementsByTagName("table");
    for (i = 0; i < tbls.length; i++) { if ((" " + tbls[i].className + " ").indexOf(" cols ") >= 0) tbls[i].style.width = "auto"; }
    var tas = c.getElementsByTagName("textarea");
    for (i = 0; i < tas.length; i++) { tas[i].style.width = "auto"; }
    var pres = c.getElementsByTagName("pre");
    for (i = 0; i < pres.length; i++) { pres[i].style.width = "auto"; pres[i].style.whiteSpace = "normal"; }
    document.body.appendChild(c);
    var natural = c.offsetWidth;
    document.body.removeChild(c);
    if (!natural || natural < 1) return;
    // Window chrome (frame + vertical scrollbar) = current outer minus the usable content area.
    var chrome = 26;
    try { var ow = window.outerWidth, bw = document.body.clientWidth; if (ow > 0 && bw > 0 && ow > bw) chrome = ow - bw; } catch (e) {}
    if (chrome < 26) chrome = 26;
    if (chrome > 80) chrome = 80;
    var target = natural + chrome + 4;
    var maxW = 1600; try { if (screen.availWidth > 0) maxW = screen.availWidth - 40; } catch (e) {}
    if (target > maxW) target = maxW;
    if (target < 760) target = 760;
    var h = 760; try { if (window.outerHeight > 0) h = window.outerHeight; } catch (e) {}
    try { window.resizeTo(target, h); } catch (e) {}
  } catch (e) { /* best-effort sizing */ }
}

// ---- boot ----
initPaths();
seedUrls();              // pre-fill Start URL rows from crawl-gui-domains.txt (else one blank row)
loadGuiConfig();         // override form defaults from crawl-gui-config.txt (if present)
toggleInputs();          // sync dependent fields AFTER the config may have changed them
updatePreview();
updateResumeBtn();       // enable "Resume" if a journal from a prior crawl is present
showTab("settings");     // open on Settings; launching a run jumps to the Run tab
fitWindowWidth();        // shrink the default (very wide) window to the content it actually needs
</script>
</body>
</html>
